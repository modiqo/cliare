      "max_probes": 512,
      "min_expected_value": 50,
      "expected_score": {
        "min": 75.0,
        "max": 100.0
      },
      "max_duration_ms": 180000
    },
    {
      "id": "gh",
      "target": "gh",
      "required": false,

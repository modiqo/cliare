{
  "schema_version": "cliare.benchmark-corpus.v1",
  "name": "local-popular-deep-cli-corpus",
  "defaults": {
    "target_concurrency": 3,
    "profile": "standard",
    "max_depth": 6,
    "max_probes": 384,
    "min_expected_value": 75,
    "concurrency": 8,
    "timeout_ms": 5000,
    "output_limit_bytes": 262144
  },
  "targets": [
    {
      "id": "cliare",
      "target": "../target/debug/cliare",
      "required": true,
      "tags": ["self", "rust", "clap", "policy", "benchmark"],
      "max_depth": 5,
      "max_probes": 256,
      "min_expected_value": 50,
      "expected_score": {
        "min": 85.0,
        "max": 100.0
      },
      "max_duration_ms": 30000
    },
    {
      "id": "rote",
      "target": "rote",
      "required": true,
      "tags": ["modiqo", "agent-harness", "deep-subcommands"],
      "profile": "deep",
      "max_depth": 8,
      "max_probes": 768,
      "min_expected_value": 50,
      "expected_score": {
        "min": 50.0,
        "max": 100.0
      },
      "max_duration_ms": 180000
    },
    {
      "id": "git",
      "target": "git",
      "required": true,
      "tags": ["popular", "deep-subcommands", "sparse-machine-output"],
      "profile": "deep",
      "max_depth": 8,
      "max_probes": 512,
      "min_expected_value": 50,
      "expected_score": {
        "min": 80.0,
        "max": 100.0
      },
      "max_duration_ms": 300000
    },
    {
      "id": "supabase",
      "target": "supabase",
      "required": true,
      "tags": ["popular", "developer-platform", "json-friendly"],
